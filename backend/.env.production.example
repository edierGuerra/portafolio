APP_ENV=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
DATABASE_ECHO=false
CORS_ORIGINS=https://tu-dominio.com

# DigitalOcean Spaces (produccion aislada)
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=tu-space-unico
DO_SPACES_KEY=prod_access_key
DO_SPACES_SECRET=prod_secret_key
DO_SPACES_PUBLIC_URL_BASE=https://tu-space-unico.nyc3.cdn.digitaloceanspaces.com
DO_SPACES_BASE_PATH=prod
DO_SPACES_DEFAULT_TTL=900
DO_SPACES_MAX_UPLOAD_BYTES=10485760
DO_SPACES_FORCE_PATH_STYLE=false
DO_SPACES_OBJECT_ACL=private
