# ============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================================================
APP_NAME="Portfolio API"
APP_VERSION="1.0.0"

# Ambiente: development | staging | production
ENVIRONMENT=development

# Debug mode (se establece automáticamente según el ambiente)
# DEBUG=False

# Número de workers de la aplicación
WORKERS=4

# Configuración del servidor
HOST=0.0.0.0
PORT=8000

# Nivel de logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================
# Orígenes permitidos (separados por comas)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Permitir credenciales en CORS
CORS_ALLOW_CREDENTIALS=true

# Métodos HTTP permitidos
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,PATCH,OPTIONS"

# Headers permitidos (usa * para permitir todos)
CORS_ALLOW_HEADERS="*"

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================
# Clave secreta para firmar tokens JWT (CAMBIAR EN PRODUCCIÓN)
# Generar con: openssl rand -hex 32
AUTH_SECRET_KEY="your-secret-key-change-me-in-production"

# Algoritmo de encriptación
AUTH_ALGORITHM=HS256

# Tiempo de vida del access token (en minutos)
AUTH_ACCESS_TOKEN_TTL=30

# Tiempo de vida del refresh token (en días)
AUTH_REFRESH_TOKEN_TTL=7

# Algoritmo para hashear passwords
AUTH_HASH_ALGORITHM=bcrypt

# Usuario inicial CMS (se crea solo si no existe ningún usuario)
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=change-me-in-production
CMS_ADMIN_NAME=Administrador
CMS_ADMIN_PROFESSIONAL_PROFILE="Administrador del CMS"
CMS_ADMIN_ABOUT_ME="Perfil administrativo inicial del portafolio."
CMS_ADMIN_PROFILE_IMAGE=""
CMS_ADMIN_LOCATION="N/A"
CMS_ADMIN_AVAILABILITY_STATUS=available

# ============================================================================
# BASE DE DATOS
# ============================================================================
# Formato: dialect+driver://username:password@host:port/database
# MySQL: mysql+aiomysql://user:password@localhost/dbname
# PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname
# SQLite: sqlite+aiosqlite:///./test.db

DATABASE_URL="mysql+aiomysql://Edier:admin@localhost/portafolio_db"

# Mostrar queries SQL en logs (útil en desarrollo)
DATABASE_ECHO=true

# Tamaño del connection pool
DATABASE_POOL_SIZE=20

# Conexiones adicionales permitidas
DATABASE_MAX_OVERFLOW=10

# Reciclar conexiones después de X segundos
DATABASE_POOL_RECYCLE=3600

# ============================================================================
# ALMACENAMIENTO EN LA NUBE - DigitalOcean Spaces
# ============================================================================
# URL del endpoint de Spaces (ej: https://nyc3.digitaloceanspaces.com)
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"

# Nombre del bucket de Spaces
DO_SPACES_BUCKET="tu-bucket-name"

# Región de Spaces (nyc3, sfo3, ams3, blr1, fra1, sgp1, syd1, etc)
DO_SPACES_REGION=nyc3

# Access Key de Spaces
DO_SPACES_KEY="your-access-key"

# Secret Key de Spaces (CAMBIAR EN PRODUCCIÓN)
DO_SPACES_SECRET="your-secret-key"

# URL base pública para acceder a objetos
DO_SPACES_PUBLIC_URL_BASE="https://tu-bucket-name.nyc3.digitaloceanspaces.com"

# Ruta base para almacenar archivos dentro del bucket (sin slashes)
DO_SPACES_BASE_PATH="uploads"

# Tiempo de vida de URLs firmadas (en segundos)
DO_SPACES_DEFAULT_TTL=900

# Tamaño máximo de carga en bytes (default: 10MB)
DO_SPACES_MAX_UPLOAD_BYTES=10485760

# Usar path-style URLs (generalmente false para Spaces)
DO_SPACES_FORCE_PATH_STYLE=false

# ACL para objetos nuevos: public-read | private | public-read-write
DO_SPACES_OBJECT_ACL=public-read

# ============================================================================
# EMAIL - Configuración SMTP
# ============================================================================
# Habilitar notificaciones por email
EMAIL_NOTIFICATIONS_ENABLED=false

# Servidor SMTP (ej: smtp.gmail.com, smtp.sendgrid.net, etc)
SMTP_HOST=""

# Puerto SMTP (usualmente 587 para TLS, 465 para SSL, 25 para sin encriptación)
SMTP_PORT=587

# Usuario/email del servidor SMTP
SMTP_USERNAME=""

# Contraseña del servidor SMTP (CAMBIAR EN PRODUCCIÓN)
SMTP_PASSWORD=""

# Email remitente
SMTP_FROM_EMAIL=""

# Email del administrador para notificaciones
ADMIN_NOTIFICATION_EMAIL=""

# Usar TLS (Transport Layer Security)
SMTP_USE_TLS=true

# Usar SSL (Secure Sockets Layer)
# Nota: No usar TLS y SSL simultáneamente
SMTP_USE_SSL=false

# ============================================================================
# NOTAS
# ============================================================================
# 1. Para desarrollo local, puedes usar esta configuración tal cual (menos email)
# 2. En producción, SIEMPRE cambiar:
#    - AUTH_SECRET_KEY
#    - DATABASE_URL (usar credenciales seguras)
#    - DO_SPACES_SECRET
#    - SMTP_PASSWORD
# 3. Para generar AUTH_SECRET_KEY seguro:
#    Linux/Mac: openssl rand -hex 32
#    Windows: python -c "import secrets; print(secrets.token_hex(32))"
# 4. Copiar este archivo a .env y completar con valores reales
