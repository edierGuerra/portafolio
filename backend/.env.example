# Database
DATABASE_URL=mysql+aiomysql://user:password@localhost/portafolio_db

# DigitalOcean Spaces (S3 compatible)
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key

# Optional values
DO_SPACES_PUBLIC_URL_BASE=https://your-bucket-name.nyc3.digitaloceanspaces.com
DO_SPACES_BASE_PATH=portfolio
DO_SPACES_DEFAULT_TTL=900
DO_SPACES_MAX_UPLOAD_BYTES=10485760
DO_SPACES_FORCE_PATH_STYLE=false

# Email notifications (optional)
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@your-domain.com
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
